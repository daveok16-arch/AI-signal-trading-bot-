# XAUUSD AI Scalping System - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# TELEGRAM BOT CONFIGURATION
# ===========================================
# Get these from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=true
TELEGRAM_PARSE_MODE=Markdown
TELEGRAM_DISABLE_WEB_PREVIEW=true
TELEGRAM_TIMEOUT=10.0
TELEGRAM_MAX_RETRIES=3
TELEGRAM_RETRY_DELAY=1.0
TELEGRAM_RATE_LIMIT_MINUTE=20
TELEGRAM_RATE_LIMIT_HOUR=100

# ===========================================
# EXNESS REFERRAL INTEGRATION (Telegram)
# ===========================================
# Referral link and promotional text
TELEGRAM_REFERRAL_LINK=https://bit.ly/4yAbSgu
TELEGRAM_PROMO_TEXT=Receive $10,000 in virtual funds and learn how to trade with a market leader.
TELEGRAM_REFERRAL_ENABLED=true
TELEGRAM_REFERRAL_EVERY_SIGNAL=true
TELEGRAM_REFERRAL_MIN_CONFIDENCE=0.0

# ===========================================
# DISCORD WEBHOOK (Optional)
# ===========================================
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url
# DISCORD_REFERRAL_LINK=https://bit.ly/4yAbSgu
# DISCORD_PROMO_TEXT=Receive $10,000 in virtual funds and learn how to trade with a market leader.
# DISCORD_REFERRAL_ENABLED=true
# DISCORD_REFERRAL_EVERY_SIGNAL=true
# DISCORD_REFERRAL_MIN_CONFIDENCE=0.0

# ===========================================
# API SERVER CONFIGURATION
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=30
API_CORS_ORIGINS=*
API_RATE_LIMIT=100
API_AUTH_ENABLED=false
API_KEY=

# ===========================================
# DASHBOARD CONFIGURATION
# ===========================================
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8501
DASHBOARD_THEME=dark
DASHBOARD_REFRESH_INTERVAL=30
DASHBOARD_AUTO_REFRESH=true

# ===========================================
# DATA ACQUISITION
# ===========================================
DATA_SYMBOL=GC=F
DATA_INTERVAL=1m
DATA_PERIOD=7d
DATA_CACHE_DIR=data/cache
DATA_CACHE_TTL=5
DATA_MAX_RETRIES=3
DATA_RETRY_DELAY=5.0
DATA_TIMEZONE=UTC

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/xauusd_scalper.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_CONSOLE=true
LOG_JSON_FORMAT=true

# ===========================================
# MODEL SETTINGS
# ===========================================
MODEL_DIR=models
DEFAULT_MODEL=ensemble
AUTO_RETRAIN=false
RETRAIN_INTERVAL=24
MIN_CONFIDENCE=0.55

# ===========================================
# BACKTESTING SETTINGS
# ===========================================
BACKTEST_INITIAL_CAPITAL=100000
BACKTEST_POSITION_SIZE=0.1
BACKTEST_MAX_POSITIONS=1
BACKTEST_COMMISSION=0.0001
BACKTEST_SLIPPAGE=0.0001
BACKTEST_STOP_LOSS=0.005
BACKTEST_TAKE_PROFIT=0.01
BACKTEST_TRAILING_STOP=true
BACKTEST_TRAILING_ACTIVATION=0.005
BACKTEST_TRAILING_DISTANCE=0.003
BACKTEST_MAX_HOLDING=15
BACKTEST_MAX_DAILY_TRADES=50
BACKTEST_MAX_DAILY_LOSS=0.02
BACKTEST_MAX_DRAWDOWN=0.15
BACKTEST_RISK_PER_TRADE=0.01
BACKTEST_POSITION_SIZING=kelly
BACKTEST_KELLY_FRACTION=0.5
BACKTEST_MIN_CONFIDENCE=0.55
BACKTEST_MIN_RISK_REWARD=1.5
BACKTEST_MAX_SPREAD=0.0005

# ===========================================
# SIGNAL GENERATION
# ===========================================
SIGNAL_CONFIDENCE_THRESHOLD=0.55
SIGNAL_MIN_RISK_REWARD=1.5
SIGNAL_CONSENSUS_THRESHOLD=0.6
SIGNAL_VOTING_METHOD=weighted
SIGNAL_SMOOTHING=3
SIGNAL_MIN_HOLD=2
SIGNAL_MAX_PER_HOUR=12
SIGNAL_COOLDOWN=5
SIGNAL_TREND_FILTER=true
SIGNAL_TREND_MA=200
SIGNAL_TREND_SLOPE=0.0001
SIGNAL_VOL_FILTER=true
SIGNAL_ATR_THRESHOLD=0.001
SIGNAL_VOLUME_FILTER=true
SIGNAL_VOLUME_MA=20
SIGNAL_VOLUME_THRESHOLD=1.2
SIGNAL_SESSION_FILTER=true
SIGNAL_ALLOWED_SESSIONS=london,new_york,overlap
SIGNAL_NEWS_FILTER=false
SIGNAL_NEWS_API_KEY=
SIGNAL_NEWS_IMPACT=high

# ===========================================
# MACHINE LEARNING
# ===========================================
MODEL_TEST_SIZE=0.2
MODEL_VAL_SIZE=0.1
MODEL_RANDOM_STATE=42
MODEL_STRATIFY=true
MODEL_CLASS_WEIGHT=balanced
MODEL_CV_FOLDS=5
MODEL_CV_STRATEGY=time_series_split
MODEL_EARLY_STOPPING=true
MODEL_PATIENCE=50
MODEL_MIN_DELTA=0.0001
MODEL_FEATURE_TOP_N=20
MODEL_SAVE_FEATURE_IMPORTANCE=true
MODEL_SAVE_PREDICTIONS=true
MODEL_SAVE_MODELS=true
MODEL_DIR=models

# ===========================================
# WALK-FORWARD VALIDATION
# ===========================================
WF_ENABLED=true
WF_TRAIN_WINDOW=5000
WF_TEST_WINDOW=1000
WF_STEP_SIZE=500
WF_MIN_TRAIN=3000
WF_EXPANDING=false
WF_PURGE_GAP=10
WF_EMBARGO=0.01

# ===========================================
# TARGET DEFINITION
# ===========================================
TARGET_TYPE=classification
TARGET_HORIZON=5
TARGET_THRESHOLD_LONG=0.0015
TARGET_THRESHOLD_SHORT=-0.0015
TARGET_NEUTRAL_ZONE=0.0005
TARGET_LABELING_METHOD=triple_barrier
TARGET_TB_UPPER_MULT=2.0
TARGET_TB_LOWER_MULT=2.0
TARGET_TB_MAX_HOLD=15
TARGET_TB_VOL_LOOKBACK=20

# ===========================================
# APPLICATION
# ===========================================
APP_ENV=production
APP_DEBUG=false
CONFIG_PATH=config/config.yaml
SIGNAL_CHECK_INTERVAL=60
BACKTEST_ON_STARTUP=false
HEALTH_CHECK_INTERVAL=30
